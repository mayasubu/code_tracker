<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeTrack</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="<%= locals.user ? '/dashboard' : '/' %>" class="nav-brand">CodeTrack</a>
        <div class="nav-links">
            <% if(locals.user) { %>
                <a href="/dashboard">Dashboard</a>
                <a href="/problems">Problems</a>
                <a href="/submissions">Submissions</a>
                <% if(locals.user.role === 'Admin') { %>
                    <a href="/admin">Admin Panel</a>
                <% } %>
                <a href="/logout" class="btn btn-outline" style="margin-left: 2rem; padding: 0.4rem 1rem;">Logout</a>
            <% } else { %>
                <a href="/login">Login</a>
                <a href="/register" class="btn btn-primary" style="margin-left: 2rem; padding: 0.4rem 1rem; color: white;">Register</a>
            <% } %>
        </div>
    </nav>
    <div class="container">
